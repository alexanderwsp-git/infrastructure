{
    "family": "mexp-lanapp-front",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::991795763909:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::991795763909:role/mexp-lanapp-front-task-role",
    "containerDefinitions": [
      {
        "name": "lanapp-ui",
        "image": "991795763909.dkr.ecr.us-east-1.amazonaws.com/mexp-lanapp-front:$IMAGE_TAG",
        "essential": true,
        "portMappings": [
          {
            "containerPort": 3000,
            "protocol": "tcp"
          }
        ],
        "environment": [
          { "name": "PORT", "value": "$PORT" },
          { "name": "NODE_ENV", "value": "production" },
          { "name": "HOSTNAME", "value": "0.0.0.0" },
          { "name": "AWS_REGION", "value": "$AWS_REGION" },
          { "name": "COGNITO_USER_POOL_ID", "value": "$COGNITO_USER_POOL_ID" },
          { "name": "COGNITO_CLIENT_ID", "value": "$COGNITO_CLIENT_ID" },
          { "name": "COGNITO_CLIENT_SECRET", "value": "$COGNITO_CLIENT_SECRET" }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/mexp-lanapp-front",
            "awslogs-region": "us-east-1",
            "awslogs-stream-prefix": "ecs"
          }
        },
        "healthCheck": {
          "command": [
            "CMD-SHELL",
            "node -e \"require('http').get('http://127.0.0.1:3000/',r=>process.exit(r.statusCode>=200&&r.statusCode<400?0:1)).on('error',()=>process.exit(1))\""
          ],
          "interval": 30,
          "timeout": 5,
          "retries": 3,
          "startPeriod": 60
        }
      }
    ]
  }
